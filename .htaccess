<IfModule mod_rewrite.c>
    RewriteEngine On
    RewriteBase /PROJECT_INFO/
    
    # If the request is for an actual file, serve it
    RewriteCond %{REQUEST_FILENAME} -f
    RewriteRule . - [L]
    
    # API Routes
    RewriteRule ^api/login$ api/auth.php [L]
    RewriteRule ^api/user$ api/user.php [L]
    RewriteRule ^api/user/([0-9]+)$ api/user.php?id=$1 [L]
    RewriteRule ^api/certificates/([0-9]+)$ api/certificates.php?user_id=$1 [L]
    RewriteRule ^api/certificates/([0-9]+)/([0-9]+)$ api/certificates.php?user_id=$1&cert_id=$2 [L]
    
    # Security: Prevent access to .env and other sensitive files
    <FilesMatch "^\.env|config\.php$">
        Order allow,deny
        Deny from all
    </FilesMatch>
    
    # Set proper content type for JSON API responses
    <FilesMatch "^api/">
        AddType application/json .php
    </FilesMatch>
    
    # If the request is for an existing file or directory, serve it directly
    RewriteCond %{REQUEST_FILENAME} -d
    RewriteRule ^ - [L]
</IfModule>

# PHP settings
<IfModule mod_php7.c>
    # Set secure PHP settings
    php_flag display_errors Off
    php_flag log_errors On
    php_value error_log "error_log.txt"
</IfModule>

# Ensure proper MIME types for JSON
<IfModule mod_headers.c>
    <FilesMatch "\.php$">
        SetEnvIf Request_URI "/api/" API_REQUEST=1
        Header set Content-Type "application/json" env=API_REQUEST
    </FilesMatch>
</IfModule>
